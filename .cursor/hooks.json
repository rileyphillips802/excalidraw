{
  "version": 1,
  "hooks": {
    "beforeReadFile": [
      {
        "command": ".cursor/hooks/block-env.sh",
        "matcher": "\\.env",
        "failClosed": true
      }
    ],
    "beforeShellExecution": [
      {
        "command": ".cursor/hooks/block-destructive.sh",
        "failClosed": true
      },
      {
        "command": ".cursor/hooks/ask-git-checkout.sh",
        "matcher": "git\\s+(checkout|switch)"
      }
    ]
  }
}
